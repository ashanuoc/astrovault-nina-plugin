<ResourceDictionary
    x:Class="Astrovault.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
    DataTemplate key MUST be: [AssemblyTitle]_Options  (NINA appends "_Options" to IPluginManifest.Name,
    which defaults to AssemblyTitle; spaces are PRESERVED — cf. ninaAPI's "Advanced API_Options").
    AssemblyTitle is "Astrovault" so the key is "Astrovault_Options".
    If AssemblyTitle changes, THIS KEY MUST CHANGE WITH IT or NINA renders an empty settings panel.
    -->
    <DataTemplate x:Key="Astrovault_Options">
        <StackPanel Orientation="Vertical" Margin="10">

            <!-- 1. HEADER -->
            <TextBlock Text="Astrovault"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,0,0,5"/>

            <!-- 2. GET YOUR API KEY HYPERLINK -->
            <TextBlock Margin="0,0,0,15">
                <Hyperlink NavigateUri="https://vault.astrospherehub.com/api-keys"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="{StaticResource PrimaryBrush}">
                    Get your API key
                </Hyperlink>
            </TextBlock>

            <!-- 3a. API ENDPOINT FIELD (Advanced — collapsed by default; the built-in default points at
                 the production host, so normal users never need to open this). -->
            <Expander IsExpanded="False"
                      Foreground="{StaticResource PrimaryBrush}"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,15">
                <Expander.Header>
                    <TextBlock Text="Advanced"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </Expander.Header>
                <StackPanel Orientation="Vertical" Margin="0,8,0,0">
                    <TextBlock Text="API Endpoint:"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,0,0,5"/>
                    <TextBox Text="{Binding ApiEndpoint, UpdateSourceTrigger=LostFocus}"
                             Background="{StaticResource SecondaryBackgroundBrush}"
                             Foreground="{StaticResource ButtonForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             FontFamily="Consolas"
                             Padding="5,4"
                             Width="350"
                             HorizontalAlignment="Left"/>
                    <TextBlock Text="Leave as default unless directed by Astrovault support. Must be https:// (http is only allowed for localhost)."
                               FontSize="11"
                               Foreground="Gray"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               HorizontalAlignment="Left"/>
                </StackPanel>
            </Expander>

            <!-- 3b. API KEY FIELD with show/hide toggle -->
            <TextBlock Text="API Key:"
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,0,0,5"/>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- PasswordBox (visible when NOT revealed) -->
                <PasswordBox x:Name="ApiKeyPasswordBox"
                             Grid.Column="0"
                             PasswordChanged="OnApiKeyPasswordChanged"
                             Background="{StaticResource SecondaryBackgroundBrush}"
                             Foreground="{StaticResource ButtonForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             Padding="5,4"
                             VerticalContentAlignment="Center"/>

                <!-- TextBox (visible when revealed, hidden by default) -->
                <TextBox x:Name="ApiKeyTextBox"
                         Grid.Column="0"
                         Text="{Binding ApiKeyInput, UpdateSourceTrigger=PropertyChanged}"
                         Background="{StaticResource SecondaryBackgroundBrush}"
                         Foreground="{StaticResource ButtonForegroundBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         FontFamily="Consolas"
                         Padding="5,4"
                         VerticalContentAlignment="Center"
                         Visibility="Collapsed"/>

                <!-- Show/Hide Toggle Button -->
                <Button x:Name="ToggleVisibilityButton"
                        Grid.Column="1"
                        Click="OnToggleApiKeyVisibility"
                        Width="50"
                        Margin="5,0,0,0"
                        Background="Transparent"
                        Foreground="{StaticResource ButtonForegroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        Content="Show"
                        ToolTip="Show/hide API key"/>
            </Grid>

            <!-- 4. BUTTONS ROW -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">

                <!-- Test Connection Button. NINA's SecondaryBackgroundButton = PrimaryBrush text on
                     SecondaryBackgroundBrush, readable in EVERY theme (the default button style sets
                     Foreground=ButtonBackgroundBrush, so plain-text buttons need a text-button style).
                     Content Margin supplies the padding the NINA button template does not bind. -->
                <Button Click="OnTestConnectionClicked"
                        IsEnabled="{Binding HasApiKeyInput}"
                        Background="#2E7D32"
                        Foreground="#FFFFFF"
                        MinHeight="30"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" Margin="12,4">
                        <ProgressBar IsIndeterminate="True"
                                     Width="16" Height="16"
                                     Margin="0,0,6,0"
                                     Visibility="{Binding IsTestingConnection, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"/>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Test Connection"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTestingConnection}" Value="True">
                                            <Setter Property="Text" Value="Testing..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <!-- Disconnect Button -->
                <Button Click="OnDisconnectClicked"
                        IsEnabled="{Binding IsConnected}"
                        Background="#C62828"
                        Foreground="#FFFFFF"
                        MinHeight="30">
                    <TextBlock Text="Disconnect" Margin="12,4"/>
                </Button>
            </StackPanel>

            <!-- 5. STATUS INDICATOR -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Ellipse Width="10" Height="10"
                         Fill="{Binding StatusDotBrush}"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"/>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource PrimaryBrush}"
                           ToolTip="{Binding StatusTooltip}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 6. SEPARATOR -->
            <TextBlock Text="Upload Settings"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,0,0,10"/>

            <!-- 7. UPLOAD TOGGLE -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <CheckBox IsChecked="{Binding UploadEnabled}"
                          IsEnabled="{Binding IsConnected}"
                          VerticalAlignment="Center"/>
                <TextBlock Text="Enable automatic upload"
                           Foreground="{StaticResource PrimaryBrush}"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Privacy Notice -->
            <TextBlock Text="When enabled, captured images are automatically uploaded to Astrovault cloud storage."
                       FontSize="11"
                       Foreground="Gray"
                       Margin="26,4,0,0"
                       TextWrapping="Wrap"
                       MaxWidth="400"
                       HorizontalAlignment="Left"/>

            <!-- Notification Verbosity -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Notifications:"
                           Foreground="{StaticResource PrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox SelectedIndex="{Binding NotificationVerbosityIndex}"
                          ToolTip="Off = silent. Errors only = notify only when an upload fails. All uploads = a popup for every completed upload."
                          Background="{StaticResource SecondaryBackgroundBrush}"
                          Foreground="{StaticResource PrimaryBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          Width="140"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="Off" Foreground="{StaticResource PrimaryBrush}"/>
                    <ComboBoxItem Content="Errors only" Foreground="{StaticResource PrimaryBrush}"/>
                    <ComboBoxItem Content="All uploads" Foreground="{StaticResource PrimaryBrush}"/>
                </ComboBox>
            </StackPanel>

            <!-- Queue Drain Order -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Upload order:"
                           Foreground="{StaticResource PrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox SelectedIndex="{Binding DrainOrderIndex}"
                          ToolTip="Order the queue uploads in. Newest first sends your latest captures before clearing an old backlog; Oldest first preserves capture order."
                          Background="{StaticResource SecondaryBackgroundBrush}"
                          Foreground="{StaticResource PrimaryBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          Width="140"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="Newest first" Foreground="{StaticResource PrimaryBrush}"/>
                    <ComboBoxItem Content="Oldest first" Foreground="{StaticResource PrimaryBrush}"/>
                </ComboBox>
            </StackPanel>

            <!-- Parallel Chunk Uploads (PERF-03) -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Parallel chunk uploads:"
                           Foreground="{StaticResource PrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox SelectedIndex="{Binding ChunkConcurrencyIndex}"
                          ToolTip="How many chunks of a large file upload at the same time. Higher is faster on fast connections; 1 (sequential) is gentlest on slow or metered links."
                          Background="{StaticResource SecondaryBackgroundBrush}"
                          Foreground="{StaticResource PrimaryBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          Width="140"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="1 (sequential)" Foreground="{StaticResource PrimaryBrush}"/>
                    <ComboBoxItem Content="2" Foreground="{StaticResource PrimaryBrush}"/>
                    <ComboBoxItem Content="3" Foreground="{StaticResource PrimaryBrush}"/>
                    <ComboBoxItem Content="4" Foreground="{StaticResource PrimaryBrush}"/>
                </ComboBox>
            </StackPanel>

            <!-- ================================================================ -->
            <!-- 8. UPLOAD STATUS SECTION                                         -->
            <!-- ================================================================ -->
            <TextBlock Text="Upload Status"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,20,0,10"/>

            <!-- 8a. WARNING BANNERS (stack all active) -->
            <TextBlock Text="Uploads paused &#x2014; API unreachable"
                       Foreground="{StaticResource NotificationErrorTextBrush}"
                       Visibility="{Binding IsCircuitOpen, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"
                       Margin="0,0,0,4"/>

            <TextBlock Text="Upload queue exceeds 10GB"
                       Foreground="{StaticResource NotificationWarningTextBrush}"
                       Visibility="{Binding IsCapacityWarning, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"
                       Margin="0,0,0,4"/>

            <TextBlock Text="{Binding StaleQueueText}"
                       Foreground="{StaticResource PrimaryBrush}"
                       Visibility="{Binding IsStaleQueue, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"
                       Margin="0,0,0,4"/>

            <TextBlock Text="{Binding CorruptQueueText}"
                       Foreground="{StaticResource NotificationWarningTextBrush}"
                       TextWrapping="Wrap"
                       Visibility="{Binding HasCorruptQueueWarning, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"
                       Margin="0,0,0,4"/>

            <!-- 8b. PROGRESS BAR (visible only during upload) -->
            <StackPanel Visibility="{Binding IsUploading, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"
                        Margin="0,4,0,8">
                <TextBlock Text="{Binding CurrentFileName}"
                           Foreground="{StaticResource PrimaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,4"/>
                <ProgressBar Minimum="0" Maximum="1"
                             Value="{Binding CurrentProgress, Mode=OneWay}"
                             Height="18"
                             Foreground="{StaticResource PrimaryBrush}"
                             Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding ProgressPercentText}"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="{Binding CurrentChunkText}"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="8,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- 8c. QUEUE COUNTS (always visible) -->
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Foreground="{StaticResource PrimaryBrush}" Margin="0,0,16,0">
                    <Run Text="Pending: "/><Run Text="{Binding PendingCount, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Foreground="{StaticResource PrimaryBrush}" Margin="0,0,16,0">
                    <Run Text="Uploading: "/><Run Text="{Binding UploadingCount, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Foreground="{StaticResource PrimaryBrush}" Margin="0,0,16,0"
                           ToolTip="Lifetime total of successfully uploaded images. Persists across restarts.">
                    <Run Text="Total uploaded: "/><Run Text="{Binding CompletedCount, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Margin="0,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasFailedUploads}" Value="True">
                                    <Setter Property="Foreground" Value="#FFE84040"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="Failed: "/><Run Text="{Binding FailedCount, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>

            <!-- 8d. ACTION BUTTONS: Reset Counts is always visible; Retry/Dismiss only when failures exist. -->
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Click="OnResetCountsClicked"
                        Background="#FDD835"
                        Foreground="#000000"
                        MinHeight="32"
                        Margin="0,0,8,0"
                        ToolTip="Resets Total uploaded and Failed to 0. Does not affect pending or in-progress uploads, and never deletes files.">
                    <TextBlock Text="Reset Counts" Margin="16,6"/>
                </Button>
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding HasFailedUploads, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}">
                    <Button Click="OnRetryAllFailedClicked"
                            Background="#2E7D32"
                            Foreground="#FFFFFF"
                            MinHeight="32"
                            Margin="0,0,8,0">
                        <TextBlock Text="Retry All" Margin="16,6"/>
                    </Button>
                    <Button Click="OnDismissAllFailedClicked"
                            Background="#616161"
                            Foreground="#FFFFFF"
                            MinHeight="32">
                        <TextBlock Text="Dismiss All" Margin="16,6"/>
                    </Button>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
